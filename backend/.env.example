# Required
OPENAI_API_KEY=
JWT_SECRET=change-me-in-production
# Full URL including scheme — every join_url returned to the client is built
# from this. Server fails to start if missing or schemeless.
HEARTHSTONE_PUBLIC_URL=http://localhost:3000

# Google Drive (optional — set up when ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
# Only used by the Google Drive OAuth callback construction. If you aren't
# using Drive, you can leave this at the default.
APP_BASE_URL=http://localhost:3000
DATABASE_URL=./hearthstone.db

# Defaults (rarely need changing)
EMBEDDING_PROVIDER=openai
CHAT_PROVIDER=openai

# Tracing (optional — leave unset to disable)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_HONEYCOMB_API_KEY
# OTEL_SERVICE_NAME=hearthstone-backend
