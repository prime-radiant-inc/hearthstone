# Required
OPENAI_API_KEY=
JWT_SECRET=change-me-in-production

# Google Drive (optional — set up when ready)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
APP_BASE_URL=http://localhost:3000
DATABASE_URL=./hearthstone.db

# Defaults (rarely need changing)
EMBEDDING_PROVIDER=openai
CHAT_PROVIDER=openai
RESEND_API_KEY=

# Tracing (optional — leave unset to disable)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_HONEYCOMB_API_KEY
# OTEL_SERVICE_NAME=hearthstone-backend
